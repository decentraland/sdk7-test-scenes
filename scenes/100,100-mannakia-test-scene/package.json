{
  "name": "mannakia-test-project",
  "version": "1.0.0",
  "description": "Test behavior of many things",
  "scripts": {
    "start": "sdk-commands start",
    "deploy": "sdk-commands deploy",
    "build": "sdk-commands build",
    "lint": "eslint src/**/*.{ts,tsx}",
    "lint:fix": "eslint --fix src/**/*.{ts,tsx}",
    "format": "prettier --config .prettierrc -c src/**/*.{ts,tsx}",
    "format:fix": "prettier -w --config .prettierrc -c src/**/*.{ts,tsx}",
    "install-sdk-protocol-squad": "npm install --save-exact @dcl/sdk@protocol-squad",
    "export-static": "sdk-commands export-static --destination static/ --realmName mannakia-dcl-scene --baseUrl https://leanmendoza.github.io/mannakia-dcl-scene/ --commsAdapter ws-room:ws-room-service.decentraland.org/rooms/mannakia-dcl-scene"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=6.0.0"
  },
  "prettier": {
    "semi": false,
    "singleQuote": true,
    "printWidth": 120,
    "trailingComma": "none"
  },
  "devDependencies": {
    "@dcl/sdk": "^7.24.5"
  },
  "dependencies": {
    "@dcl-sdk/utils": "^1.2.6",
    "dcl-crypto-toolkit": "^1.0.0-20231213161359.commit-4e6bbb6"
  }
}
